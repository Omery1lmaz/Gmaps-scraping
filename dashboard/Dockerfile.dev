FROM node:22-alpine

WORKDIR /app

RUN npm config set fetch-retry-maxtimeout 600000 && \
    npm config set fetch-retries 5

COPY package*.json ./

RUN npm install --legacy-peer-deps

# Copy source for initial build (will be overridden by volume in dev)
COPY . .

EXPOSE 5173

# Development mode - .env will be created by docker-compose command
CMD ["npm", "run", "dev"]